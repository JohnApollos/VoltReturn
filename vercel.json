{
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "nextjs"
        },
        "backend": {
            "root": "backend",
            "entrypoint": "app/main.py"
        }
    },
    "rewrites": [
        {
            "source": "/api/v1/:path*",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/((?!api/v1).*)*",
            "destination": {
                "type": "service",
                "service": "frontend"
            }
        }
    ]
}
